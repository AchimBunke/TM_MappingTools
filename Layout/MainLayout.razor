@using TM_MappingTools.Pages
@using TM_MappingTools.Utils
@inject TM_MappingTools.Services.FileTypeManager FileTypeManager
@inject TM_MappingTools.Services.OperationHistoryService OperationHistoryService
@inject IJSRuntime JS
@inherits LayoutComponentBase
@implements IDisposable
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://github.com/AchimBunke/TM_MappingTools" target="_blank">Mapping Tools GitHub</a>
            <a href="https://github.com/AchimBunke/TM_CSharpMapping" target="_blank">CSharp Mapping GitHub</a>
            <a href="https://trackmania.exchange/usershow/131189" target="_blank">TMX</a>
        </div>

        <div class="file-io-row px-4 py-3 border-bottom">
            <div class="file-io-split">
                <FileLoader FileService="CurrentFileService"
                            NoFileMessage="No file loaded."
                            DropHintMessage="Drop a .Clip.Gbx, .Map.Gbx, or .Item.Gbx file anywhere in this area"
                            Accept="@TM_MappingTools.Services.FileTypeManager.GetFileFilter()"
                            OnFileSelected="OnFileSelected" />
                <div class="operations-history-list small">
                    <div class="operations-history-title">Operations Done</div>
                    <ul class="list-unstyled mb-0">
                        @for (var i = 0; i < OperationHistoryService.OperationsHistory.Count; i++)
                        {
                            var op = OperationHistoryService.OperationsHistory[i];
                            var idx = i+1;
                            <li>
                                <span class="operation-id">@idx</span>
                                <span class="operation-key" title="@op">@op</span> 
                            </li>
                            
                        }
                        @if (OperationHistoryService.OperationsHistory.Count == 0)
                        {
                            <li class="operation-empty">(empty)</li>
                        }
                    </ul>
                </div>

                <div class="file-download-area">
                    @if (FileTypeManager.CurrentService?.HasFile == true)
                    {
                        <button class="btn btn-primary" @onclick="Download">Export @FileTypeManager.CurrentContentType</button>
                    }
                    else
                    {
                        <span class="text-muted small">Load a file to enable export.</span>
                    }
                </div>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private Services.FileService CurrentFileService = new();

    protected override void OnInitialized()
    {
        CurrentFileService.FileChanged += OnFileChanged;
        FileTypeManager.FileTypeChanged += OnFileTypeChanged;
        OperationHistoryService.HistoryChanged += OnOperationHistoryChanged;
    }

    public void Dispose()
    {
        CurrentFileService.FileChanged -= OnFileChanged;
        FileTypeManager.FileTypeChanged -= OnFileTypeChanged;
        OperationHistoryService.HistoryChanged -= OnOperationHistoryChanged;
    }

    private void OnOperationHistoryChanged() => InvokeAsync(StateHasChanged);

    private void OnFileTypeChanged() => InvokeAsync(StateHasChanged);

    private async void OnFileChanged()
    {
        OperationHistoryService.Clear();
    }

    private async Task OnFileSelected(Microsoft.AspNetCore.Components.Forms.IBrowserFile file)
    {
        try
        {
            await FileTypeManager.LoadFileAsync(file);

            // Sync UI state only when the typed service actually loaded content.
            if (FileTypeManager.CurrentService?.HasFile == true)
            {
                await CurrentFileService.SetFileAsync(file);
            }
            else
            {
                CurrentFileService.Clear();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading file: {ex.Message}");
            CurrentFileService.Clear();
        }
    }

    private async Task Download()
    {
        var stream = FileTypeManager.GetDownloadStream();
        if (stream != null && FileTypeManager.CurrentService != null)
        {
            var streamRef = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("downloadFileFromStream", FileTypeManager.CurrentService.FileName, streamRef);
        }
    }

}

