@using TM_MappingTools.Pages
@using TM_MappingTools.Utils
@inject TM_MappingTools.Services.ClipFileService FileService
@inject TM_MappingTools.Services.OperationHistoryService OperationHistoryService
@inject IJSRuntime JS
@inherits LayoutComponentBase
@implements IDisposable
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://github.com/AchimBunke/TM_MappingTools" target="_blank">Mapping Tools GitHub</a>
            <a href="https://github.com/AchimBunke/TM_CSharpMapping" target="_blank">CSharp Mapping GitHub</a>
            <a href="https://trackmania.exchange/usershow/131189" target="_blank">TMX</a>
        </div>

        <div class="file-io-row px-4 py-3 border-bottom">
            <div class="file-io-split">
                @* <div @ref="dropZoneElement" class="file-drop-area"
                     @ondrop:preventDefault="true" @ondrop="OnDrop"
                     @ondragover:preventDefault="true" @ondragover="OnDragOver">
                    <InputFile @ref="inputFile" id="layoutFilePicker" OnChange="OnFileSelected" class="visually-hidden" />

                    <div class="file-drop-content">
                        @if (FileService.HasFile)
                        {
                            <div class="file-name">@FileService.FileName</div>
                            <div class="file-size">@FileHelper.GetFormattedFileSize(FileService.FileSize) (original)</div>
                        }
                        else
                        {
                            <div class="file-name text-muted">No Clip loaded</div>
                        }

                        <div class="file-drop-hint">
                            Drop a .Clip.Gbx file anywhere in this area, or
                            <label for="layoutFilePicker" class="file-open-link">choose a file from disk</label>.
                        </div>
                    </div>
                </div> *@
                <FileLoader FileService="FileService"
                            NoFileMessage="No Clip loaded."
                            DropHintMessage="Drop a .Clip.Gbx file anywhere in this area"
                            Accept=".Clip.Gbx" />
                <div class="operations-history-list small">
                    <div class="operations-history-title">Operations Done</div>
                    <ul class="list-unstyled mb-0">
                        @for (var i = 0; i < OperationHistoryService.OperationsHistory.Count; i++)
                        {
                            var op = OperationHistoryService.OperationsHistory[i];
                            var idx = i+1;
                            <li>
                                <span class="operation-id">@idx</span>
                                <span class="operation-key" title="@op">@op</span> 
                            </li>
                            
                        }
                        @if (OperationHistoryService.OperationsHistory.Count == 0)
                        {
                            <li class="operation-empty">(empty)</li>
                        }
                    </ul>
                </div>

                <div class="file-download-area">
                    @if (FileService.HasFile)
                    {
                        <button class="btn btn-primary" @onclick="Download">Export Clip</button>
                    }
                    else
                    {
                        <span class="text-muted small">Load a Clip to enable export.</span>
                    }
                </div>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        FileService.FileChanged += OnFileChanged;
        OperationHistoryService.HistoryChanged += OnOperationHistoryChanged;
    }

    public void Dispose()
    {
        FileService.FileChanged -= OnFileChanged;
        OperationHistoryService.HistoryChanged -= OnOperationHistoryChanged;
    }

    private void OnOperationHistoryChanged() => InvokeAsync(StateHasChanged);

    private async void OnFileChanged()
    {
        OperationHistoryService.Clear();
    }

    private async Task Download()
    {
        using var stream = FileService.GetDownloadStream();
        var streamRef = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("downloadFileFromStream", FileService.FileName, streamRef);
    }

}
