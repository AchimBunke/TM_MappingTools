<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">TM Mapping Tools</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="nav-menu-icon bi-house-door-fill" aria-hidden="true"></i> Home
            </NavLink>
        </div>

        <hr class="nav-separator" />

        @* Clip Tools *@
        <div class="nav-tools-section @(IsToolSectionActive("Clip") ? "nav-tools-section-active" : "")">
            <div class="nav-item px-3 @(IsToolSectionActive("Clip") ? "nav-item-active" : "")">
                <NavLink class="nav-link" href="player-attached-triangles">
                    <i class="nav-menu-icon bi-paperclip" aria-hidden="true"></i>Player-Attached 3DTriangles
                </NavLink>
            </div>

            <div class="nav-item px-3 @(IsToolSectionActive("Clip") ? "nav-item-active" : "")">
                <NavLink class="nav-link" href="optimize-keyframe-animations">
                    <i class="nav-menu-icon bi-bezier"></i> Optimize Keyframe Animations
                </NavLink>
            </div>

            <div class="nav-item px-3 @(IsToolSectionActive("Clip") ? "nav-item-active" : "")">
                <NavLink class="nav-link" href="optimize-triangle-compression">
                    <i class="nav-menu-icon bi-grid-3x3"></i> Optimize Triangle Compression
                </NavLink>
            </div>

            <div class="nav-item px-3 @(IsToolSectionActive("Clip") ? "nav-item-active" : "")">
                <NavLink class="nav-link" href="import-triangle-animation">
                    <i class="nav-menu-icon bi-collection-play"></i> Import Triangle Animation
                </NavLink>
            </div>

            <hr class="nav-separator" />
        </div>

        @* Map Tools *@
        <div class="nav-tools-section @(IsToolSectionActive("Map") ? "nav-tools-section-active" : "")">
            <div class="nav-item px-3 @(IsToolSectionActive("Map") ? "nav-item-active" : "")">
                <NavLink class="nav-link" href="map-item-replacer">
                    <i class="nav-menu-icon bi-shuffle" aria-hidden="true"></i> Map Item Replacer
                </NavLink>
            </div>

            <hr class="nav-separator" />
        </div>

        @* Item Tools *@
        <div class="nav-tools-section nav-tools-section-active">
            <div class="nav-item px-3 nav-item-active">
                <NavLink class="nav-link" href="moving-item-creator">
                    <i class="nav-menu-icon bi-box-arrow-in-right" aria-hidden="true"></i> Moving Item Creator
                </NavLink>
            </div>

            <hr class="nav-separator" />
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="about">
                <i class="nav-menu-icon bi-info-circle" aria-hidden="true"></i> About
            </NavLink>
        </div>

    </nav>
</div>

@code {
    @inject TM_MappingTools.Services.FileTypeManager FileTypeManager

    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        FileTypeManager.FileTypeChanged += OnFileTypeChanged;
    }

    private void OnFileTypeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private bool IsToolSectionActive(string contentType)
    {
        return string.IsNullOrEmpty(FileTypeManager.CurrentContentType)
            || string.Equals(FileTypeManager.CurrentContentType, contentType, StringComparison.Ordinal);
    }
}

