<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">TM Mapping Tools</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="nav-menu-icon bi-house-door-fill" aria-hidden="true"></i> Home
            </NavLink>
        </div>

        <hr class="nav-separator" />

        @foreach (var group in ToolRegistryService.ToolEntries.GroupBy(t => t.Category))
        {
            var isGroupActive = group.Any(t => IsToolSelectionActive(t.SelectionActive));
            <div class="nav-tools-section @(isGroupActive ? "nav-tools-section-active" : "")">
                @foreach (var tool in group)
                {
                    <div class="nav-item px-3 @(IsToolSelectionActive(tool.SelectionActive) ? "nav-item-active" : "")">
                        <NavLink class="nav-link" href="@tool.Href">
                            <i class="nav-menu-icon bi @tool.IconClass" aria-hidden="true"></i> @tool.Title
                        </NavLink>
                    </div>
                }

                <hr class="nav-separator" />
            </div>
        }

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="about">
                <i class="nav-menu-icon bi-info-circle" aria-hidden="true"></i> About
            </NavLink>
        </div>

        <hr class="nav-separator" />

        <div class="nav-item px-3 nav-item-theme-toggle">
            <button class="nav-link theme-toggle-btn" @onclick="ToggleTheme"
                    title="@(isDark ? "Switch to Light Mode" : "Switch to Dark Mode")">
                <i class="nav-menu-icon bi @(isDark ? "bi-sun-fill" : "bi-moon-stars-fill")" aria-hidden="true"></i>
                @(isDark ? "Light Mode" : "Dark Mode")
            </button>
        </div>

    </nav>
</div>

@code {
    @inject TM_MappingTools.Services.FileTypeManager FileTypeManager
    @inject TM_MappingTools.Services.ToolRegistryService ToolRegistryService
    @inject IJSRuntime JS

    private bool collapseNavMenu = true;
    private bool isDark = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        FileTypeManager.FileTypeChanged += OnFileTypeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("getTheme");
            isDark = theme == "dark";
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        var newTheme = await JS.InvokeAsync<string>("toggleTheme");
        isDark = newTheme == "dark";
    }

    private void OnFileTypeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private bool IsToolSelectionActive(TM_MappingTools.Model.ToolSelectionActive selectionActive)
    {
        if (selectionActive == TM_MappingTools.Model.ToolSelectionActive.All)
            return true;

        if (string.IsNullOrEmpty(FileTypeManager.CurrentContentType))
            return true;

        return selectionActive switch
        {
            TM_MappingTools.Model.ToolSelectionActive.Clip => string.Equals(FileTypeManager.CurrentContentType, "Clip", StringComparison.Ordinal),
            TM_MappingTools.Model.ToolSelectionActive.Map => string.Equals(FileTypeManager.CurrentContentType, "Map", StringComparison.Ordinal),
            TM_MappingTools.Model.ToolSelectionActive.Item => string.Equals(FileTypeManager.CurrentContentType, "Item", StringComparison.Ordinal),
            _ => true
        };
    }
}

