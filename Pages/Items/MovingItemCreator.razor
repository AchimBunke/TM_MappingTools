@page "/moving-item-creator"
@inherits TM_MappingTools.Pages.SessionStorageComponentBase
@using GBX.NET.Engines.GameData
@using System.Text
@using System.IO.Compression
@using TM_GenericMapping.Messaging
@using TM_MappingTools.Services

@inject TM_MappingTools.Services.ToolMessageService ToolMessageService


<PageTitle>Moving Item Creator</PageTitle>

<ToolPageLayout IconClass="bi-box-arrow-in-right" Title="Moving Item Creator" Description="Create moving items."
                HelpDescription="What this tool changes and how to tune it safely.">
    <IORow>
        <ToolIORow>
            <InputContent>
                <ToolCard Title="Animation Template (Optional)"
                          Description="Load one .Item.Gbx to copy moving animation data and placement from.">
                    <FileLoader FileService="TemplateItemFileService" NoFileMessage="No template item loaded."
                                DropHintMessage="Drop a .Item.Gbx template item in this area" Accept=".Item.Gbx"
                                MessageSource="Moving Item Creator" />
                </ToolCard>
                <ToolCard Title="Items To Convert"
                          Description="Load all .Item.Gbx files that should become moving items.">
                    <FileLoader FileService="ItemModelsFileService" NoFileMessage="No files loaded."
                                DropHintMessage="Drop all items you want to convert to moving here" Accept=".Item.Gbx"
                                AllowMultiple="true" MessageSource="Moving Item Creator" />
                </ToolCard>
            </InputContent>
            <ExportContent>
                <ToolCard Title="Export" Class="tool-export-panel" BodyClass="tool-export-panel-body">
                    <ExportPanel EmptyMessage="Run Execute to generate export content."
                                 DownloadAllFileName="MovingItems.zip" Items="_exportItems" />
                </ToolCard>
            </ExportContent>
        </ToolIORow>
    </IORow>
    <Sidebar>
        <ToolCard Title="Input Selection" BodyClass="small text-muted">
            <div>Template item loaded: @(TemplateItemFileService.Item != null ? "Yes" : "No")</div>
            <div>Items to convert: @ItemModelsFileService.Files.Count</div>
        </ToolCard>
    </Sidebar>
    <Main>
        <ToolCard Title="Actions">
            <ExecuteAction Execute="ExecuteToolAsync" UseSelectedTracks="false" MessageSource="Moving Item Creator"
                           ExecutionTargetOverwrite="Generate Moving Items" Tooltip="Execute the tool with the loaded items."
                           CanExecute="CanExecuteTool" />
        </ToolCard>
        <ToolCard Title="Parameters">
            <ParameterInput Definitions="parameterDefinitions" Values="parameterValues"
                            ValuesChanged="OnParameterValuesChanged" />
        </ToolCard>
    </Main>
    <HelpContent>
        <h3>What happens when you click Execute</h3>
        <p>The MovingItemCreator will generate moving items based on the loaded source items and the specified
            parameters. At the end a zip file containing all the generated moving items is downloaded.
        </p>

        <p>The generated moving item animations are based on the <strong>Animation Template Item</strong>
            if it exists, otherwise they will contain a default rotating animation.
        </p>
        <p>The generater will try to create the same properties as the source item (like mesh, materials, etc.)
            but some differences might occur. Some materials might not be visible in moving items. Some moving
            items might contain more vertices and triangles as the source item depending which mesh encoding was
            used.
        </p>
        <p>This is a list of the compatibility of many default materials: <a
            href="https://github.com/AchimBunke/TM_MovingTrackGenerator/wiki">TM_MovingTrackGenerator
            Github</a>.
        </p>
        <h3>Author Name</h3>
        <p>The author name encoded in the moving item.</p>
        <h3>Item Name Postfix</h3>
        <p>The postfix appended to the name of the source item for the generated moving item. This is useful to
            easily distinguish the generated moving items from the source items.
        </p>
        <h3>Practical workflow</h3>
        <p>If you want to copy a specific animation to all moving items, load the item containing those into the 'Animation Template' input.
        </p>
        <p>Then either drag and drop all items you want to convert to moving, or select them from disk in the
            'Items to Convert' section.
        </p>
        <p>Insert your desired author name and item name prefix and suffix in the parameters section.
            
        </p>
        <p>Wait until you downloaded a zip and extract those files into your Items folder.

        </p>
        <p><strong>Note:</strong> If you create new items that didnt exist when you opened Trackmania, you might
            need to restart the game to see them. To avoid this, instead of creating new files, overwrite
            existing items. Then only the Editor needs to be reopened. (Sometimes this does not work)
        </p>
    </HelpContent>
</ToolPageLayout>

    
@code {
    [SessionStored] private ItemFileService TemplateItemFileService = default!;
    [SessionStored] private FileService ItemModelsFileService = default!;
    [SessionStored] private IReadOnlyList<ExportableItem>? _exportItems;
    
    private readonly List<ToolParameterDefinition> parameterDefinitions = new()
    {
        new()
        {
            Key = "author",
            Label = "Author Name",
            Tooltip = "The author of the moving item.",
            Kind = ToolParameterKind.Text,
            DefaultValue = string.Empty,
        },
         new()
        {
            Key = "namePrefix",
            Label = "Item Name Prefix",
            Tooltip = "The prefix to prepend to the name of the source item.",
            Kind = ToolParameterKind.Text,
            DefaultValue = "",
        },
        new()
        {
            Key = "nameSuffix",
            Label = "Item Name Suffix",
            Tooltip = "The suffix to append to the name of the source item.",
            Kind = ToolParameterKind.Text,
            DefaultValue = "",
        }
       
    };

    [SessionStored] private ToolParameterValues parameterValues = new();

    protected override void OnInitialized()
    {
        base.OnInitialized();

        ItemModelsFileService.FileChanged += OnFileChanged;

    }
    public void Dispose()
    {
        ItemModelsFileService.FileChanged -= OnFileChanged;
    }
    async void OnFileChanged()
    {
        await InvokeAsync(StateHasChanged);
    }
    private Task OnParameterValuesChanged(ToolParameterValues values)
    {
        parameterValues = values;
        return Task.CompletedTask;
    }

    private bool CanExecuteTool()
    {
        return ItemModelsFileService.HasFiles;
    }
    private async Task<ExecuteActionResult> ExecuteToolAsync()
    {
        var sourceAnimationItem = TemplateItemFileService.Item;

        var itemFileService = new ItemFileService();

        var meshExtractor = new TM_GenericMapping.Items.MeshExtractor();

        var meshBuilderSettings = new TM_GenericMapping.Items.MeshBuilder.MeshBuilderSettings
        {
            Author = parameterValues.GetString("author", "TM_MappingTools.MovingItemCreator"),
        };
        var meshBuilder = new TM_GenericMapping.Items.MeshBuilder(meshBuilderSettings);

        var movingItemCreatorSettings = new TM_GenericMapping.Items.MovingItemCreator.MovingItemCreatorSettings
        {
            MovingItemAnimationTemplate = sourceAnimationItem,
        };
        var movingItemCreator = new TM_GenericMapping.Items.MovingItemCreator(
            meshExtractor,
            meshBuilder,
            movingItemCreatorSettings);
        
        string namePrefix = parameterValues.GetString("namePrefix", string.Empty);
        string nameSuffix = parameterValues.GetString("nameSuffix", string.Empty);

   
        var generatedItems = new List<(string FileName, CGameItemModel Item)>();

        int numFails = 0;
        int numSuccess = 0;
        foreach (var file in ItemModelsFileService.Files)
        {
            try
            {
                await itemFileService.SetFileAsync(file);
                var item = itemFileService.Item;
                if (item == null)
                {
                    ToolMessageService.AddError($"Failed to load item from file: {file.Name}", "Moving Item Creator");
                    continue;
                }
           
                var movingItemResult = movingItemCreator.CreateMovingItem(item);

                if (movingItemResult.IsFailure)
                {
                    ToolMessageService.AddError($"Failed to create moving item for file: {file.Name}", movingItemResult, "Moving Item Creator");
                    numFails++;
                }
                else
                {
                    movingItemResult.Value.Name = namePrefix + item.Name + nameSuffix;
                    generatedItems.Add((FixFileName(file.Name, namePrefix, nameSuffix), movingItemResult.Value));
                    numSuccess++;
                }
            }
            catch (Exception e)
            {
                ToolMessageService.AddException(e, $"Failed to create moving item for file: {file.Name}", "Moving Item Creator");
                numFails++;
            }
        }
        if (generatedItems.Count > 0)
        {
            _exportItems = generatedItems.Select(x =>
            {
                using var s = new MemoryStream();
                x.Item.Save(s, new GBX.NET.GbxWriteSettings { CloseStream = false });
                var bytes = s.ToArray();
                return new ExportableItem { FileName = x.FileName, GetBytes = () => bytes };
            }).ToArray();
            StateHasChanged();
        }

        if (numFails > 0 && numSuccess > 0)
            return new ExecuteActionResult(ExecuteActionResultStatus.Warning, $"{numSuccess} moving items created successfully, but {numFails} failed. Check output for details.");
        else if (numFails > 0)
            return new ExecuteActionResult(ExecuteActionResultStatus.Failure, $"Failed to create moving items from all files. Check output for details.");
        else
            return new ExecuteActionResult(ExecuteActionResultStatus.Success, $"Successfully created moving items from all files.");
    }

    string FixFileName(string originalName, string prefix, string suffix)
    {
        if (string.IsNullOrEmpty(originalName) || (string.IsNullOrEmpty(suffix) && string.IsNullOrEmpty(prefix)))
            return originalName;

        const string itemsSuffix = ".Item.Gbx";
        if (originalName.EndsWith(itemsSuffix, StringComparison.OrdinalIgnoreCase))
            return prefix + originalName[..^itemsSuffix.Length] + suffix + itemsSuffix;

        return originalName;
    }
}