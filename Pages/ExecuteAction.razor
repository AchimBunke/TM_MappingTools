@using TM_GenericMapping.Messaging
@using TM_MappingTools.Model
@inject TM_MappingTools.Services.ToolMessageService ToolMessageService

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 p-3">
    <span class="text-muted small">
        @if (UseSelectedTracks)
        {
            <span>Selected tracks:
                @if (!string.IsNullOrWhiteSpace(SelectedTrackPreview))
                {
                    <span> <strong>@SelectedTrackPreview</strong></span>
                }
            </span>
        }
        else
        {
            <span><strong>@ExecutionTargetOverwrite</strong></span>
        }
            
    </span>
    <button type="button" class="btn btn-primary @(isExecuting ? "executing" : "")" @onclick="ExecuteAsync"
            disabled="@(!EffectiveCanExecute || isExecuting)" title="@Tooltip">
        @if (isExecuting)
        {
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            <span>Executing...</span>
        }
        else
        {
            <span>Execute</span>
        }
    </button>
</div>

@if (lastRunState != ExecuteRunState.None)
{
    <div class="execute-status execute-status-@lastRunState.ToString().ToLowerInvariant()" role="status" aria-live="polite">
        <span class="bi @GetRunStateIcon(lastRunState)" aria-hidden="true"></span>
        <span class="execute-status-text">@lastRunSummary</span>
        <button type="button" class="btn btn-link btn-sm execute-status-link" @onclick="OpenOutput">
            Open output
        </button>
    </div>
}



@code {
    private const int FullPreviewTrackCount = 5;
    private const int MaxPreviewLength = 70;
    private const int AbbreviatedPreviewTrackCount = 5;

    [Parameter] public IReadOnlyList<TrackData> SelectedTracks { get; set; } = Array.Empty<TrackData>();
    [Parameter] public bool UseSelectedTracks { get; set; } = true;
    [Parameter] public string ExecutionTargetOverwrite { get; set; } = string.Empty;
    [Parameter] public string MessageSource { get; set; } = string.Empty;
    [Parameter] public string Tooltip { get; set; } = string.Empty;
  
    [Parameter] public Func<bool>? CanExecute { get; set; }
    [Parameter] public Func<Task<ExecuteActionResult>>? Execute { get; set; }

    private bool isExecuting;
    private ExecuteRunState lastRunState = ExecuteRunState.None;
    private string lastRunSummary = string.Empty;
    private bool EffectiveCanExecute =>
        !isExecuting &&
        Execute != null &&
        (CanExecute?.Invoke() ?? true) &&
        (!UseSelectedTracks || SelectedTracks.Count > 0);

    private string? ResolvedMessageSource =>
        !string.IsNullOrWhiteSpace(MessageSource)
            ? MessageSource
            : (!string.IsNullOrWhiteSpace(ExecutionTargetOverwrite) ? ExecutionTargetOverwrite : null);

    
    private async Task ExecuteAsync()
    {
        if (!EffectiveCanExecute) return;

        isExecuting = true;
        lastRunState = ExecuteRunState.None;
        lastRunSummary = string.Empty;

        StateHasChanged();
        await Task.Yield();
        try
        {
            ExecuteActionResult result = await Execute!.Invoke();
            if (result.Status == ExecuteActionResultStatus.Success)
            {
                if (result.Message == null)
                {
                    if (UseSelectedTracks)
                    {
                        result = result with { Message = $"Action finished successfully for {SelectedTracks.Count} track(s)." };
                    }
                    else
                    {
                        result = result with { Message = "Action finished successfully." };
                    }
                }
                ToolMessageService.AddSuccess(result.Message, ResolvedMessageSource);
                lastRunState = ExecuteRunState.Success;
                lastRunSummary = result.Message;
            }
            else if (result.Status == ExecuteActionResultStatus.Warning)
            {
                if (result.Message == null)
                {
                    if (UseSelectedTracks)
                    {
                        result = result with { Message = $"Action completed with warnings for {SelectedTracks.Count} track(s)." };
                    }
                    else
                    {
                        result = result with { Message = "Action completed with warnings." };
                    }
                }
                ToolMessageService.AddWarning(result.Message, ResolvedMessageSource);
                ToolMessageService.RequestReveal();
                lastRunState = ExecuteRunState.Warning;
                lastRunSummary = result.Message;
            }
            else if (result.Status == ExecuteActionResultStatus.Failure)
            {
                if (result.Message == null)
                {
                    if (UseSelectedTracks)
                    {
                        result = result with { Message = $"Action failed for {SelectedTracks.Count} track(s)." };
                    }
                    else
                    {
                        result = result with { Message = "Action failed." };
                    }
                }
                ToolMessageService.AddError(result.Message, ResolvedMessageSource);
                ToolMessageService.RequestReveal();
                lastRunState = ExecuteRunState.Error;
                lastRunSummary = result.Message;
            }
        }
        catch(Exception ex)
        {
            ToolMessageService.AddException(ex, source: ResolvedMessageSource);
            ToolMessageService.RequestReveal();
            lastRunState = ExecuteRunState.Error;
            lastRunSummary = ex.Message;
        }
        finally
        {
            isExecuting = false;
            StateHasChanged();
        }
    }
    private string SelectedTrackPreview
    {
        get
        {
            if (SelectedTracks.Count == 0)
            {
                return string.Empty;
            }

            var names = SelectedTracks
                .Select(GetTrackDisplayName)
                .ToList();

            var fullPreview = string.Join(", ", names);
            var shouldAbbreviate = SelectedTracks.Count > FullPreviewTrackCount || fullPreview.Length > MaxPreviewLength;

            if (!shouldAbbreviate)
            {
                return fullPreview;
            }

            var abbreviatedCount = Math.Min(AbbreviatedPreviewTrackCount, names.Count);
            while (abbreviatedCount > 1)
            {
                var preview = string.Join(", ", names.Take(abbreviatedCount));
                if (preview.Length <= MaxPreviewLength) break;
                abbreviatedCount--;
            }
            var abbreviatedPreview = string.Join(", ", names.Take(abbreviatedCount));
            return $"{abbreviatedPreview}, ...";
        }
    }

    private static string GetTrackDisplayName(TrackData track)
    {
        if (!string.IsNullOrWhiteSpace(track.TrackName))
        {
            return track.TrackName;
        }

        return $"Track {track.TrackIndex}";
    }

    private void OpenOutput() => ToolMessageService.RequestReveal();

    private static string GetRunStateIcon(ExecuteRunState state) => state switch
    {
        ExecuteRunState.Success => "bi-check-circle-fill",
        ExecuteRunState.Error => "bi-exclamation-octagon-fill",
        _ => "bi-info-circle-fill",
    };

    private enum ExecuteRunState
    {
        None,
        Success,
        Warning,
        Error,
    }

    
}
