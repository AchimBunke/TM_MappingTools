    protected override void OnParametersSet()
    {
        foreach (var definition in Definitions)
        {
            if (!Values.Contains(definition.Key))
            {
                Values.Set(definition.Key, definition.GetDefaultValue());
            }
        }
    }

    private string GetInputId(ToolParameterDefinition definition)
    {
        return $"tool_parameter_{definition.Key}";
    }

    private static string? GetNumericAttribute(double? value)
    {
        return value?.ToString(CultureInfo.InvariantCulture);
    }

    private static string FormatFloat(double value)
    {
        return value.ToString(CultureInfo.InvariantCulture);
    }

    private static bool GetDefaultBool(ToolParameterDefinition definition)
    {
        return definition.GetDefaultValue() is bool boolValue && boolValue;
    }

    private static int GetDefaultInt(ToolParameterDefinition definition)
    {
        if (definition.GetDefaultValue() is int intValue)
        {
            return intValue;
        }

        return 0;
    }

    private static double GetDefaultDouble(ToolParameterDefinition definition)
    {
        return definition.GetDefaultValue() switch
        {
            double doubleValue => doubleValue,
            float floatValue => floatValue,
            int intValue => intValue,
            _ => 0d,
        };
    }

    private static string GetDefaultString(ToolParameterDefinition definition)
    {
        return definition.GetDefaultValue()?.ToString() ?? string.Empty;
    }

    private static bool IsLargeTextParameter(ToolParameterDefinition definition)
    {
        return definition.Kind == ToolParameterKind.Text && definition.LongValue;
    }

    private Task OnBoolChanged(string key, ChangeEventArgs args)
    {
        var value = args.Value is bool boolValue && boolValue;
        return SetValueAsync(key, value);
    }

    private Task OnIntChanged(string key, ChangeEventArgs args)
    {
        var rawValue = Convert.ToString(args.Value, CultureInfo.InvariantCulture);

        if (int.TryParse(rawValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsedValue))
        {
            return SetValueAsync(key, parsedValue);
        }

        return Task.CompletedTask;
    }

    private Task OnFloatChanged(string key, ChangeEventArgs args)
    {
        var rawValue = Convert.ToString(args.Value, CultureInfo.InvariantCulture);

        if (double.TryParse(rawValue, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.InvariantCulture, out var parsedValue))
        {
            return SetValueAsync(key, parsedValue);
        }

        return Task.CompletedTask;
    }

    private Task OnTextChanged(string key, ChangeEventArgs args)
    {
        return SetValueAsync(key, Convert.ToString(args.Value, CultureInfo.InvariantCulture) ?? string.Empty);
    }

    private async Task SetValueAsync(string key, object? value)
    {
        Values.Set(key, value);
        await ValuesChanged.InvokeAsync(Values);
    }
}