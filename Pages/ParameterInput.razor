@using System.Globalization
@using System.Numerics
@using TM_MappingTools.Model

<div class="parameter-input">
    <div class="parameter-input-list">
        @foreach (var definition in Definitions)
        {
            <div class="parameter-input-field @(IsWideParameter(definition) ? "parameter-input-field-wide" : string.Empty)">
                <div class="parameter-input-header">
                    <label class="parameter-input-label" for="@GetInputId(definition)" title="@definition.Tooltip">@definition.Label</label>
                    @if (!string.IsNullOrWhiteSpace(definition.Tooltip))
                    {
                        <span class="parameter-input-help" title="@definition.Tooltip" aria-label="@definition.Tooltip">?</span>
                    }
                </div>

                @switch (definition.Kind)
                {
                    case ToolParameterKind.Bool:
                        <label class="parameter-input-checkbox" for="@GetInputId(definition)">
                            <input id="@GetInputId(definition)"
                                   type="checkbox"
                                   checked="@Values.GetBool(definition.Key, GetDefaultBool(definition))"
                                   @onchange="@(args => OnBoolChanged(definition.Key, args))" />
                            <span>Enabled</span>
                        </label>
                        break;

                    case ToolParameterKind.Int:
                        <input id="@GetInputId(definition)"
                               class="form-control"
                               type="number"
                               min="@GetNumericAttribute(definition.Min)"
                               max="@GetNumericAttribute(definition.Max)"
                               step="@GetNumericAttribute(definition.Step)"
                               value="@Values.GetInt(definition.Key, GetDefaultInt(definition))"
                               @onchange="@(args => OnIntChanged(definition.Key, args))" />
                        break;

                    case ToolParameterKind.Float:
                        <input id="@GetInputId(definition)"
                               class="form-control"
                               type="number"
                               min="@GetNumericAttribute(definition.Min)"
                               max="@GetNumericAttribute(definition.Max)"
                               step="@(GetNumericAttribute(definition.Step) ?? "0.01")"
                               value="@FormatFloat(Values.GetDouble(definition.Key, GetDefaultDouble(definition)), definition.Step)"
                               @onchange="@(args => OnFloatChanged(definition, args))" />
                        break;

                    case ToolParameterKind.Enum:
                        <select id="@GetInputId(definition)"
                                class="form-select"
                                value="@Values.GetString(definition.Key, GetDefaultString(definition))"
                                @onchange="@(args => OnTextChanged(definition.Key, args))">
                            @foreach (var option in definition.Options)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </select>
                        break;

                    case ToolParameterKind.Text:
                        @if (definition.LongValue)
                        {
                            <textarea id="@GetInputId(definition)"
                                      class="form-control parameter-input-textarea"
                                      rows="4"
                                      @oninput="@(args => OnTextChanged(definition.Key, args))">@Values.GetString(definition.Key, GetDefaultString(definition))</textarea>
                        }
                        
                        else
                        {
                            <input id="@GetInputId(definition)"
                                   class="form-control"
                                   type="text"
                                   value="@Values.GetString(definition.Key, GetDefaultString(definition))"
                                   @oninput="@(args => OnTextChanged(definition.Key, args))" />
                        }
                        break;

                    case ToolParameterKind.Vector2:
                        <div class="parameter-vector-grid parameter-vector-grid-2">
                            @for (var i = 0; i < 2; i++)
                            {
                                var componentIndex = i;
                                <div class="parameter-vector-inline-item">
                                    <span class="parameter-vector-label">@(componentIndex == 0 ? "X" : "Y")</span>
                                    <input id="@GetComponentInputId(definition, componentIndex)"
                                           class="form-control"
                                           type="number"
                                           min="@GetNumericAttribute(definition.Min)"
                                           max="@GetNumericAttribute(definition.Max)"
                                           step="@(GetNumericAttribute(definition.Step) ?? "0.01")"
                                           value="@FormatFloat(GetVectorComponent(definition, componentIndex), definition.Step)"
                                           aria-label="@(componentIndex == 0 ? "X" : "Y")"
                                           @onchange="@(args => OnVectorComponentChanged(definition, componentIndex, args))" />
                                </div>
                            }
                        </div>
                        <input class="form-control parameter-vector-raw"
                               type="text"
                               value="@GetVectorText(definition)"
                               @onchange="@(args => OnVectorTextChanged(definition, args))"
                               placeholder="e.g. 0, 1" />
                        break;

                    case ToolParameterKind.Vector3:
                        <div class="parameter-vector-grid parameter-vector-grid-3">
                            @for (var i = 0; i < 3; i++)
                            {
                                var componentIndex = i;
                                <div class="parameter-vector-inline-item">
                                    <span class="parameter-vector-label">@(componentIndex == 0 ? "X" : componentIndex == 1 ? "Y" : "Z")</span>
                                    <input id="@GetComponentInputId(definition, componentIndex)"
                                           class="form-control"
                                           type="number"
                                           min="@GetNumericAttribute(definition.Min)"
                                           max="@GetNumericAttribute(definition.Max)"
                                           step="@(GetNumericAttribute(definition.Step) ?? "0.01")"
                                           value="@FormatFloat(GetVectorComponent(definition, componentIndex), definition.Step)"
                                           aria-label="@(componentIndex == 0 ? "X" : componentIndex == 1 ? "Y" : "Z")"
                                           @onchange="@(args => OnVectorComponentChanged(definition, componentIndex, args))" />
                                </div>
                            }
                        </div>
                        <input class="form-control parameter-vector-raw"
                               type="text"
                               value="@GetVectorText(definition)"
                               @onchange="@(args => OnVectorTextChanged(definition, args))"
                               placeholder="e.g. 0, 1, 2" />
                        break;

                    case ToolParameterKind.Vector4:
                        <div class="parameter-vector-grid parameter-vector-grid-4">
                            @for (var i = 0; i < 4; i++)
                            {
                                var componentIndex = i;
                                <div class="parameter-vector-inline-item">
                                    <span class="parameter-vector-label">@(componentIndex switch { 0 => "X", 1 => "Y", 2 => "Z", _ => "W" })</span>
                                    <input id="@GetComponentInputId(definition, componentIndex)"
                                           class="form-control"
                                           type="number"
                                           min="@GetNumericAttribute(definition.Min)"
                                           max="@GetNumericAttribute(definition.Max)"
                                           step="@(GetNumericAttribute(definition.Step) ?? "0.01")"
                                           value="@FormatFloat(GetVectorComponent(definition, componentIndex), definition.Step)"
                                           aria-label="@(componentIndex switch { 0 => "X", 1 => "Y", 2 => "Z", _ => "W" })"
                                           @onchange="@(args => OnVectorComponentChanged(definition, componentIndex, args))" />
                                </div>
                            }
                        </div>
                        <input class="form-control parameter-vector-raw"
                               type="text"
                               value="@GetVectorText(definition)"
                               @onchange="@(args => OnVectorTextChanged(definition, args))"
                               placeholder="e.g. 0, 1, 2, 3" />
                        break;

                    case ToolParameterKind.Quaternion:
                        <div class="parameter-vector-grid parameter-vector-grid-3">
                            @for (var i = 0; i < 3; i++)
                            {
                                var componentIndex = i;
                                <div class="parameter-vector-inline-item">
                                    <span class="parameter-vector-label">@(componentIndex == 0 ? "X" : componentIndex == 1 ? "Y" : "Z")</span>
                                    <input id="@GetComponentInputId(definition, componentIndex)"
                                           class="form-control"
                                           type="number"
                                           min="@GetNumericAttribute(definition.Min)"
                                           max="@GetNumericAttribute(definition.Max)"
                                           step="@(GetNumericAttribute(definition.Step) ?? "0.1")"
                                           value="@FormatFloat(GetRotationEulerDegrees(definition)[componentIndex], definition.Step ?? 0.1d)"
                                           aria-label="@(componentIndex == 0 ? "X" : componentIndex == 1 ? "Y" : "Z")"
                                           @onchange="@(args => OnQuaternionEulerComponentChanged(definition, componentIndex, args))" />
                                </div>
                            }
                        </div>
                        <input class="form-control parameter-vector-raw"
                               type="text"
                               value="@GetQuaternionEulerText(definition)"
                               @onchange="@(args => OnQuaternionEulerTextChanged(definition, args))"
                               placeholder="e.g. 0, 90, 0" />
                        break;

                    default:
                        <input id="@GetInputId(definition)"
                               class="form-control"
                               type="text"
                               value="@Values.GetString(definition.Key, GetDefaultString(definition))"
                               @oninput="@(args => OnTextChanged(definition.Key, args))" />
                        break;
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<ToolParameterDefinition> Definitions { get; set; } = Array.Empty<ToolParameterDefinition>();
    [Parameter] public ToolParameterValues Values { get; set; } = new();
    [Parameter] public EventCallback<ToolParameterValues> ValuesChanged { get; set; }

@* private readonly List<ToolParameterDefinition> parameterDefinitions = new()
