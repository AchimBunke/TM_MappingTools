@using System.Globalization
@using TM_MappingTools.Model

<div class="parameter-input">
    <div class="parameter-input-list">
        @foreach (var definition in Definitions)
        {
            <div class="parameter-input-field @(IsLargeTextParameter(definition) ? "parameter-input-field-wide" : string.Empty)">
                <div class="parameter-input-header">
                    <label class="parameter-input-label" for="@GetInputId(definition)" title="@definition.Tooltip">@definition.Label</label>
                    @if (!string.IsNullOrWhiteSpace(definition.Tooltip))
                    {
                        <span class="parameter-input-help" title="@definition.Tooltip" aria-label="@definition.Tooltip">?</span>
                    }
                </div>

                @switch (definition.Kind)
                {
                    case ToolParameterKind.Bool:
                        <label class="parameter-input-checkbox" for="@GetInputId(definition)">
                            <input id="@GetInputId(definition)"
                                   type="checkbox"
                                   checked="@Values.GetBool(definition.Key, GetDefaultBool(definition))"
                                   @onchange="@(args => OnBoolChanged(definition.Key, args))" />
                            <span>Enabled</span>
                        </label>
                        break;

                    case ToolParameterKind.Int:
                        <input id="@GetInputId(definition)"
                               class="form-control"
                               type="number"
                               min="@GetNumericAttribute(definition.Min)"
                               max="@GetNumericAttribute(definition.Max)"
                               step="@GetNumericAttribute(definition.Step)"
                               value="@Values.GetInt(definition.Key, GetDefaultInt(definition))"
                               @onchange="@(args => OnIntChanged(definition.Key, args))" />
                        break;

                    case ToolParameterKind.Float:
                        <input id="@GetInputId(definition)"
                               class="form-control"
                               type="number"
                               min="@GetNumericAttribute(definition.Min)"
                               max="@GetNumericAttribute(definition.Max)"
                               step="@(GetNumericAttribute(definition.Step) ?? "0.01")"
                               value="@FormatFloat(Values.GetDouble(definition.Key, GetDefaultDouble(definition)))"
                               @onchange="@(args => OnFloatChanged(definition.Key, args))" />
                        break;

                    case ToolParameterKind.Enum:
                        <select id="@GetInputId(definition)"
                                class="form-select"
                                value="@Values.GetString(definition.Key, GetDefaultString(definition))"
                                @onchange="@(args => OnTextChanged(definition.Key, args))">
                            @foreach (var option in definition.Options)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </select>
                        break;

                    case ToolParameterKind.Text:
                        @if (definition.LongValue)
                        {
                            <textarea id="@GetInputId(definition)"
                                      class="form-control parameter-input-textarea"
                                      rows="4"
                                      @oninput="@(args => OnTextChanged(definition.Key, args))">@Values.GetString(definition.Key, GetDefaultString(definition))</textarea>
                        }
                        else
                        {
                            <input id="@GetInputId(definition)"
                                   class="form-control"
                                   type="text"
                                   value="@Values.GetString(definition.Key, GetDefaultString(definition))"
                                   @oninput="@(args => OnTextChanged(definition.Key, args))" />
                        }
                        break;

                    default:
                        <input id="@GetInputId(definition)"
                               class="form-control"
                               type="text"
                               value="@Values.GetString(definition.Key, GetDefaultString(definition))"
                               @oninput="@(args => OnTextChanged(definition.Key, args))" />
                        break;
                }
            </div>
        }
    </div>
</div>

@code {
