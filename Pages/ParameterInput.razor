@using TM_MappingTools.Model

<div>
    <div class="parameter-input-list">
        @foreach (var group in GetRenderGroups())
        {
            @if (group.GroupKey != null)
            {
                <div class="parameter-input-field parameter-input-group-field" style="grid-column: span @group.Definitions.Count">
                    @if (!string.IsNullOrEmpty(group.GroupLabel))
                    {
                        <div class="parameter-input-group-header">@group.GroupLabel</div>
                    }
                    <div class="parameter-input-group-inner" style="grid-template-columns: repeat(@group.Definitions.Count, minmax(0, 1fr))">
                        @foreach (var groupDef in group.Definitions)
                        {
                            <div class="parameter-input-group-item">
                                <div class="parameter-input-header">
                                    <label class="parameter-input-label" for="@GetInputId(groupDef)" title="@groupDef.Tooltip">@groupDef.Label</label>
                                    @if (groupDef.IsOptional || !string.IsNullOrWhiteSpace(groupDef.Tooltip))
                                    {
                                        <div class="parameter-input-header-actions">
                                            @if (groupDef.IsOptional)
                                            {
                                                <input type="checkbox"
                                                       class="parameter-optional-checkbox"
                                                       checked="@IsEnabled(groupDef)"
                                                       title="@(IsEnabled(groupDef) ? "Disable this parameter" : "Enable this parameter")"
                                                       @onchange="@(args => OnOptionalToggled(groupDef, args))" />
                                            }
                                            @if (!string.IsNullOrWhiteSpace(groupDef.Tooltip))
                                            {
                                                <span class="parameter-input-help" title="@groupDef.Tooltip" aria-label="@groupDef.Tooltip">?</span>
                                            }
                                        </div>
                                    }
                                </div>
                                <ParameterInputControl Definition="groupDef" Values="Values"
                                                       ValuesChanged="ValuesChanged"
                                                       Enabled="@IsEnabled(groupDef)" />
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                var def = group.Definitions[0];
                <div class="parameter-input-field @(IsWideParameter(def) ? "parameter-input-field-wide" : string.Empty)">
                    <div class="parameter-input-header">
                        <label class="parameter-input-label" for="@GetInputId(def)" title="@def.Tooltip">@def.Label</label>
                        @if (def.IsOptional || !string.IsNullOrWhiteSpace(def.Tooltip))
                        {
                            <div class="parameter-input-header-actions">
                                @if (def.IsOptional)
                                {
                                    <input type="checkbox"
                                           class="parameter-optional-checkbox"
                                           checked="@IsEnabled(def)"
                                           title="@(IsEnabled(def) ? "Disable this parameter" : "Enable this parameter")"
                                           @onchange="@(args => OnOptionalToggled(def, args))" />
                                }
                                @if (!string.IsNullOrWhiteSpace(def.Tooltip))
                                {
                                    <span class="parameter-input-help" title="@def.Tooltip" aria-label="@def.Tooltip">?</span>
                                }
                            </div>
                        }
                    </div>
                    <ParameterInputControl Definition="def" Values="Values"
                                           ValuesChanged="ValuesChanged"
                                           Enabled="@IsEnabled(def)" />
                </div>
            }
        }
    </div>
    @{
        var dictDefs = GetDictionaryDefinitions();
    }
    @if (dictDefs.Count > 0)
    {
        <div class="parameter-dict-list">
            @foreach (var dictDef in dictDefs)
            {
                <ParameterDictionaryControl Definition="dictDef" Values="Values" ValuesChanged="ValuesChanged" />
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<ToolParameterDefinition> Definitions { get; set; } = Array.Empty<ToolParameterDefinition>();
    [Parameter] public ToolParameterValues Values { get; set; } = new();
    [Parameter] public EventCallback<ToolParameterValues> ValuesChanged { get; set; }

    protected override void OnParametersSet()
    {
        foreach (var definition in Definitions)
        {
            if (!Values.Contains(definition.Key))
            {
                Values.Set(definition.Key, definition.GetDefaultValue());
                // Optional with no explicit DefaultValue start as disabled
                if (definition.IsOptional && definition.DefaultValue == null)
                    Values.SetParameterEnabled(definition.Key, false);
            }
        }
    }

    private static string GetInputId(ToolParameterDefinition definition)
        => $"tool_parameter_{definition.Key}";

    private static bool IsWideParameter(ToolParameterDefinition definition)
    {
        if (definition.Kind == ToolParameterKind.Text)
            return definition.LongValue;

        return definition.Kind is ToolParameterKind.Vector2 or ToolParameterKind.Vector3 or ToolParameterKind.Vector4 or ToolParameterKind.Quaternion;
    }

    private bool IsEnabled(ToolParameterDefinition definition)
        => !definition.IsOptional || Values.IsParameterEnabled(definition.Key);

    private Task OnOptionalToggled(ToolParameterDefinition definition, ChangeEventArgs args)
    {
        Values.SetParameterEnabled(definition.Key, args.Value is bool b && b);
        return ValuesChanged.InvokeAsync(Values);
    }

    private IReadOnlyList<ToolParameterDefinition> GetDictionaryDefinitions()
        => Definitions.Where(d => d.Kind == ToolParameterKind.Dictionary).ToList();

    private IReadOnlyList<RenderGroup> GetRenderGroups()
    {
        var result = new List<RenderGroup>();
        var groupLookup = new Dictionary<string, RenderGroup>(StringComparer.Ordinal);

        foreach (var def in Definitions)
        {
            if (def.Kind == ToolParameterKind.Dictionary) continue;
            if (!string.IsNullOrEmpty(def.GroupKey))
            {
                if (!groupLookup.TryGetValue(def.GroupKey, out var group))
                {
                    group = new RenderGroup(def.GroupKey, def.GroupLabel, new List<ToolParameterDefinition>());
                    groupLookup[def.GroupKey] = group;
                    result.Add(group);
                }
                group.Definitions.Add(def);
            }
            else
            {
                result.Add(new RenderGroup(null, null, new List<ToolParameterDefinition> { def }));
            }
        }

        return result;
    }

    private sealed class RenderGroup(string? GroupKey, string? GroupLabel, List<ToolParameterDefinition> Definitions)
    {
        public string? GroupKey { get; } = GroupKey;
        public string? GroupLabel { get; } = GroupLabel;
        public List<ToolParameterDefinition> Definitions { get; } = Definitions;
    }
}