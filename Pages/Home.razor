@page "/"

<PageTitle>Home</PageTitle>

<div class="home-hero">
    <div class="home-hero-icon">
        <span class="bi bi-camera-reels" aria-hidden="true"></span>
    </div>
    <h1 class="home-hero-title">TM Mapping Tools</h1>
    <p class="home-hero-subtitle">A collection of tools for TrackMania mappers to edit and optimize MediaTracker clips.</p>
    <p class="home-hero-hint">
        Load a <code>.Clip.Gbx</code> file using the drop zone above, then select a tool from the sidebar.
    </p>
</div>

<div class="home-tools-section">
    <h2 class="home-section-title">Available Tools</h2>
    <div class="home-tool-cards">
        <a href="player-attached-triangles" class="home-tool-card">
            <span class="bi bi-paperclip home-tool-card-icon" aria-hidden="true"></span>
            <div class="home-tool-card-body">
                <div class="home-tool-card-title">Player-Attached 3D Triangles</div>
                <div class="home-tool-card-desc">Attach 3D Triangles to the Player.</div>
            </div>
        </a>
        <a href="optimize-keyframe-animations" class="home-tool-card">
            <span class="bi bi-bezier2 home-tool-card-icon" aria-hidden="true"></span>
            <div class="home-tool-card-body">
                <div class="home-tool-card-title">Optimize Keyframe Animations</div>
                <div class="home-tool-card-desc">Reduce redundant keyframes in MediaTracker animations to reduce filesize.</div>
            </div>
        </a>
    </div>
</div>