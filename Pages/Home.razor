@page "/"
@inject TM_MappingTools.Services.ToolRegistryService ToolRegistryService

<PageTitle>Home</PageTitle>

<div class="home-hero">
    <div class="home-hero-icon">
        <span class="bi-house-door-fill" aria-hidden="true"></span>
    </div>
    <h1 class="home-hero-title">TM Mapping Tools</h1>
    <p class="home-hero-subtitle">A collection of tools for TrackMania mappers to edit and optimize Maps.</p>
    <p class="home-hero-hint">
        Select a tool from the sidebar and load a <code>.Clip.Gbx</code>, <code>.Map.Gbx</code> or <code>.Item.Gbx</code> using the drop zone above.
    </p>
</div>

<div class="home-tools-section">
    <h2 class="home-section-title">Available Tools (@ToolRegistryService.ToolEntries.Count)</h2>
    <div class="home-tool-groups">
        @foreach (var group in ToolRegistryService.ToolEntries.GroupBy(t => t.Category))
        {
            <section class="home-tool-group">
                <h3 class="home-group-title">@group.Key</h3>
                <div class="home-tool-grid">
                    @foreach (var tool in group)
                    {
                        <a href="@tool.Href" class="home-tool-card">
                            <span class="home-tool-card-top">
                                <i class="bi @tool.IconClass home-tool-card-icon" aria-hidden="true"></i>
                                <span class="home-tool-card-title">@tool.Title</span>
                            </span>
                            <span class="home-tool-card-desc">@tool.Description</span>
                        </a>
                    }
                </div>
            </section>
        }
    </div>
</div>
