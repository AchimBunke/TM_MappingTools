@page "/optimize-keyframe-animations"
@inject TM_MappingTools.Services.OperationHistoryService OperationHistoryService
@inject TM_MappingTools.Services.SessionStorage SessionStorage


<PageTitle>Optimize Keyframe Animations</PageTitle>

<div class="tool-page">
    <ToolPageHeader IconClass="bi bi-bezier"
                    Title="Optimize Keyframe Animations"
                    Description="Reduce redundant keyframes in MediaTracker animations to reduce file size. This operation may take some time depending on the size of track and mesh.">
        <HeaderActions>
            <button type="button"
                    class="btn btn-outline-secondary btn-sm tool-help-toggle"
                    @onclick="ToggleHelpPanel"
                    aria-expanded="@showHelpPanel"
                    aria-controls="optimizeHelpPanel">
                <span class="bi @(showHelpPanel ? "bi-x-circle" : "bi-info-circle")" aria-hidden="true"></span>
                @(showHelpPanel ? "Hide details" : "How this works")
            </button>
        </HeaderActions>
    </ToolPageHeader>
    <div class="tool-page-body">
        <div class="tool-page-layout @(showHelpPanel ? "tool-page-layout-with-help" : string.Empty)">
            <div class="tool-page-sidebar">
                <div class="tool-panel tool-action-panel">
                    <div class="tool-panel-header">
                        <h2 class="tool-panel-title">Track Selection</h2>
                    </div>
                    <TrackSelector @bind-SelectedTracks="selectedTracks" />
                </div>
            </div>
            <div class="tool-page-main">
                <div class="tool-panel tool-action-panel">
                    <div class="tool-panel-header">
                        <h2 class="tool-panel-title">Actions</h2>
                    </div>
                    <ExecuteAction SelectedTracks="selectedTracks" Execute="ExecuteToolAsync" UseSelectedTracks="true"
                                   Tooltip="Execute the tool with the selected tracks. This may take some time!" />
                </div>

                <div class="tool-panel">
                    <div class="tool-panel-header">
                        <h2 class="tool-panel-title">Parameters</h2>
                    </div>
                    <ParameterInput Definitions="parameterDefinitions" Values="parameterValues"
                                    ValuesChanged="OnParameterValuesChanged" />
                </div>

            </div>

            @if (showHelpPanel)
            {
                <ToolHelpSidebar PanelId="optimizeHelpPanel"
                                 Title="Detailed Info"
                                 Description="What this tool changes and how to tune it safely.">
                    <h3>What happens when you click Execute</h3>
                    <p>The optimizer iterates over each selected MediaTracker track and analyzes the keyframe sequence. It removes keyframes and position points that do not materially change animation quality under the chosen error settings.</p>
                    <p>It uses the Douglas-Peucker algorithm to simplify the keyframe paths while maintaining the overall shape of the animation which works as follows:
                        <ul class="text-muted small">
                            <li>It takes 3 keyframes, 2 outer and 1 inner.</li>
                            <li>It calculates the deviation of the inner keyframe from the linearly interpolated path between the outer keyframes.</li>
                            <li>If the maximum deviation is below the specified error threshold, the intermediate keyframes can be removed without significantly affecting animation quality, because Trackmania will interpolate 2 keyframes linearly anyway.</li>
                            <li>This process is repeated recursively until no more keyframes can be removed within the error threshold.</li>
                        </ul>
                    </p>

                    <h3>Error Metric</h3>
                    <p><strong>Max</strong> keeps the highest single deviation under the threshold. It is stricter on local spikes and usually preserves sharp details better.</p>
                    <p><strong>Root Mean Square</strong> balances errors across the whole segment. It can remove more keys, but may allow small local deviations.</p>

                    <h3>Error Threshold</h3>
                    <p>Lower values preserve quality and remove fewer keys. Higher values are more aggressive and reduce file size more, but can introduce visible motion differences.</p>
                    <p>A threshold of 0.01 with Max error metric means that even if the position deviates by 0.01 units from a linear motion, it will be considered on the path of linear motion and can be removed.</p>

                    <h3>Practical workflow</h3>
                    <p>Start with a low threshold and preview in-game. Increase gradually until you see acceptable size savings without visible artifacts. Repeat for tracks with different motion complexity.</p>
                    
                </ToolHelpSidebar>
            }
        </div>
    </div>
</div>



@code {
    private List<TrackData> selectedTracks = new();
    private bool showHelpPanel;
    private readonly List<ToolParameterDefinition> parameterDefinitions = new()
    {
        new()
        {
            Key = "errorMetric",
            Label = "Error Metric",
            Tooltip = "The error metric used to determine the quality of the keyframe optimization.",
            Kind = ToolParameterKind.Enum,
            DefaultValue = "Max",
            Options = new[]
            {
                new ToolParameterOption { Value = "Max", Label = "Max" },
                new ToolParameterOption { Value = "RootMeanSquare", Label = "Root Mean Square" },
            },
        },
        new()
        {
            Key = "errorThreshold",
            Label = "Error Threshold",
            Tooltip = "The maximum allowable error for keyframe optimization. The higher the threshold, the more aggressive the optimization will be at the potential cost of animation quality.",
            Kind = ToolParameterKind.Float,
            DefaultValue = 0.00001d,
            Min = 0.0d,
            Max = 1.0d,
            Step = 0.00001d,
        },
    };

    private ToolParameterValues parameterValues = new();

    protected override void OnInitialized(){
        base.OnInitialized();

        if(SessionStorage.Has(member: nameof(parameterDefinitions)))
            parameterValues = SessionStorage.Get<ToolParameterValues>(member: nameof(parameterDefinitions))!;
        else
            SessionStorage.Set(member: nameof(parameterDefinitions), value: parameterValues);

    }

    private Task OnParameterValuesChanged(ToolParameterValues values)
    {
        parameterValues = values;
        return Task.CompletedTask;
    }

    private void ToggleHelpPanel()
    {
        showHelpPanel = !showHelpPanel;
    }

    private async Task<string?> ExecuteToolAsync()
    {
        var errorMetricStr = parameterValues.GetString("errorMetric");
        var errorMetric = Enum.TryParse<KeyFrameAnimationOptimizer.ErrorMetric>(errorMetricStr, out var parsedErrorMetric)
            ? parsedErrorMetric
            : KeyFrameAnimationOptimizer.ErrorMetric.Max;
        var errorThreshold = parameterValues.GetFloat("errorThreshold");
        var optimizationInfo = new KeyFrameAnimationOptimizer.ClipOptimizationInfo();

        foreach (var trackData in selectedTracks)
        {
            var optimizerSettings = new KeyFrameAnimationOptimizer.OptimizerSettings
            {
                ErrorMetric = errorMetric,
                ErrorThreshold = errorThreshold
            };
            var result = KeyFrameAnimationOptimizer.OptimizeTrack(trackData.MediaTrack.Track, optimizerSettings);
            optimizationInfo.TrackOptimizationInfos.Add(result);
        }

        OperationHistoryService.AddOperation("Optimized Keyframe Animations");
        return BuildSuccessMessage(optimizationInfo);
    }

    private string? BuildSuccessMessage(KeyFrameAnimationOptimizer.ClipOptimizationInfo optimizationInfo)
    {
        if (optimizationInfo == null || optimizationInfo.TrackOptimizationInfos.Count == 0)
        {
            return null;
        }

        return $"Optimization completed for {optimizationInfo.TrackOptimizationInfos.Count} track(s)! Removed {optimizationInfo.TotalRemovedKeyFrameCount} keyframes and {optimizationInfo.TotalRemovedPositionCount} positions across all optimized tracks.";
    }
}
