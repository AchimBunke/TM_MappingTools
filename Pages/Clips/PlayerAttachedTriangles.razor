@page "/player-attached-triangles"
@inherits TM_MappingTools.Pages.SessionStorageComponentBase
@inject TM_MappingTools.Services.GlobalClipHistoryService OperationHistoryService
@inject TM_MappingTools.Services.ClipFileService SharedClipFileService
@implements IDisposable

<PageTitle>Player Attached Triangles</PageTitle>

<ToolPageLayout IconClass="bi-paperclip" Title="Player-Attached 3D Triangles"
                Description="Attach 3D triangles to the player. These tracks will move relative to the car."
                HelpDescription="How player-attached triangles work and when to use visibility ensurance.">
    <IORow>
        <ToolIORow>
            <InputContent>
                <ToolCard Title="Input Clip" Description="Load the clip that should be modified.">
                    <FileLoader FileService="SharedClipFileService" NoFileMessage="No clip loaded."
                                DropHintMessage="Drop a .Clip.Gbx file in this area" Accept=".Clip.Gbx"
                                MessageSource="Player-Attached 3D Triangles" />
                </ToolCard>
            </InputContent>
            <HistoryContent>
                <ToolCard Title="Operation History" Description="Recent clip operations in this session."
                          Class="tool-operation-history-panel">
                    <ToolOperationHistory EmptyMessage="(nothing yet)" OperationHistoryService="OperationHistoryService" />
                </ToolCard>
            </HistoryContent>
            <ExportContent>
                <ToolCard Title="Export" Description="Export the updated clip." Class="tool-export-panel"
                          BodyClass="tool-export-panel-body">
                    <ExportPanel FileService="SharedClipFileService" />
                </ToolCard>
            </ExportContent>
        </ToolIORow>
    </IORow>
    <Sidebar>
        <ToolCard Title="Track Selection">
            <TrackSelector Clip="SharedClipFileService.Clip" @bind-SelectedTracks="selectedTracks" />
        </ToolCard>
    </Sidebar>
    <Main>
        <ToolCard Title="Actions">
            <ExecuteAction SelectedTracks="selectedTracks" Execute="ExecuteToolAsync" UseSelectedTracks="true"
                           MessageSource="Player-Attached 3D Triangles" Tooltip="Execute the tool with the selected tracks." />
        </ToolCard>
        <ToolCard Title="Parameters">
            <ParameterInput Definitions="parameterDefinitions" Values="parameterValues"
                            ValuesChanged="OnParameterValuesChanged" />
        </ToolCard>
    </Main>
    <HelpContent>
        <h3>What happens when you click Execute</h3>
        <p>For each selected track, this tool converts triangle geometry so it moves relative to the player vehicle
            rather than staying fixed in world space.</p>
            <h3>Ensure Visibility</h3>
            <p>When enabled, extra vertices are added to reduce culling artifacts so triangles remain visible from all
                camera angles and distances.</p>
                <h3>Ensurance Vertex Distance</h3>
                <p>This sets how far those helper vertices are placed. Larger values may improve culling robustness.</p>
                <h3>Practical workflow</h3>
                <p>If you want your relative triangles to remain visible from all camera angles, enable Ensure Visibility. The
                    only time you should disable it is if you purposely want to only show these triangles when driving in a
                    certain direction. Though even then the culling behavior is insanely hard to predict and depends on screen
                    resolution and camera settings.</p>
                </HelpContent>
            </ToolPageLayout>

@code {
    [SessionStored] private List<TrackData> selectedTracks = new();

    private readonly List<ToolParameterDefinition> parameterDefinitions = new()
    {
        new()
        {
            Key = "ensureVisibility",
            Label = "Ensure Visibility",
            Tooltip = "If disabled, 3DTriangles may not render depending on your camera direction and distance. Enabling this will ensure they are always visible by added extra vertices to the track preventing erroneous culling.",
            Kind = ToolParameterKind.Bool,
            DefaultValue = true,
        },
        new()
        {
            Key = "ensuranceVertexDistance",
            Label = "Ensurance Vertex Distance",
            Tooltip = "If Ensure Visibility is enabled, this controls the distance of the extra vertices added to ensure visibility. Low values may cause erroneous culling to appear.",
            Kind = ToolParameterKind.Float,
            DefaultValue = 10000f,
            Min = 0.1,
            Max = 100000,
            Step = 100,
        },
    };

    [SessionStored] private ToolParameterValues parameterValues = new();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        SharedClipFileService.FileChanged += OnClipFileChanged;
    }

    public void Dispose() => SharedClipFileService.FileChanged -= OnClipFileChanged;

    private async void OnClipFileChanged() => await InvokeAsync(StateHasChanged);
    private Task OnParameterValuesChanged(ToolParameterValues values)
    {
        parameterValues = values;
        return Task.CompletedTask;
    }

    private async Task<ExecuteActionResult> ExecuteToolAsync()
    {
        foreach (var trackData in selectedTracks)
        {
            TracksUtils.MakeTrianglesRelative(trackData.MediaTrack.Track,
                parameterValues.GetBool("ensureVisibility"),
                parameterValues.GetFloat("ensuranceVertexDistance"));
        }
        OperationHistoryService.AddOperation("Player Attached Triangles");

        return new ExecuteActionResult(ExecuteActionResultStatus.Success);
    }
}
