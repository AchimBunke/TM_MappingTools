@page "/embedded-item-extractor"
@inherits TM_MappingTools.Pages.SessionStorageComponentBase
@using TM_GenericMapping.Messaging
@using TM_MappingTools.Services
@inject TM_MappingTools.Services.ToolMessageService ToolMessageService


<PageTitle>Embedded Item Extractor</PageTitle>

<ToolPageLayout IconClass="bi-box-arrow-up" Title="Embedded Item Extractor"
                Description="Extract embedded items and blocks from a map."
                HelpDescription="What this tool changes and how to tune it safely.">
    <IORow>
        <ToolIORow>
            <InputContent>
                <ToolCard Title="Input Map" Description="Load the map that contains embedded blocks and items.">
                    <FileLoader FileService="MapFileService" NoFileMessage="No map loaded."
                                DropHintMessage="Drop a .Map.Gbx file in this area" Accept=".Map.Gbx"
                                MessageSource="Embedded Item Extractor" />
                </ToolCard>
            </InputContent>
            <ExportContent>
                <ToolCard Title="Export"
                          Class="tool-export-panel" BodyClass="tool-export-panel-body">
                    <ExportPanel EmptyMessage="Run Execute to generate export content." Items="_exportItems" />
                </ToolCard>
               
            </ExportContent>
        </ToolIORow>
    </IORow>
    <Sidebar>
        <ToolCard Title="Input Selection">
            <div class="small text-muted">
                <div>Map loaded: @(MapFileService.Challenge != null ? "Yes" : "No")</div>
            </div>
        </ToolCard>
    </Sidebar>
    <Main>
        <ToolCard Title="Actions">
            <ExecuteAction Execute="ExecuteToolAsync" UseSelectedTracks="false" CanExecute="CanExecuteTool"
                           ExecutionTargetOverwrite="Extract embedded Items and Blocks" MessageSource="Embedded Item Extractor"
                           Tooltip="Extract embedded items and blocks from a map." />
        </ToolCard>
        <ToolCard Title="Parameters">
            <ParameterInput Definitions="parameterDefinitions" Values="parameterValues"
                            ValuesChanged="OnParameterValuesChanged" />
        </ToolCard>
    </Main>
    <HelpContent>
        <h3>What happens when you click Execute</h3>
        <p>The tool will extract embedded items and blocks from the selected map and save them in a zip file.</p>
        <p>The extracted zip contains a folder structure according to the embedded items and blocks hierarchy.</p>
    </HelpContent>
</ToolPageLayout>

@code {
    [SessionStored] private MapFileService MapFileService = default!;
    [SessionStored] private IReadOnlyList<ExportableItem>? _exportItems;
    private readonly List<ToolParameterDefinition> parameterDefinitions = new()
    {
    };

    [SessionStored] private ToolParameterValues parameterValues = new();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        MapFileService.FileChanged += OnFileChanged;
    }
    public void Dispose()
    {
        MapFileService.FileChanged -= OnFileChanged;
    }

    private Task OnParameterValuesChanged(ToolParameterValues values)
    {
        parameterValues = values;
        return Task.CompletedTask;
    }
    async void OnFileChanged()
    {
        _exportItems = null;
        await InvokeAsync(StateHasChanged);
    }

    private bool CanExecuteTool()
    {
        return MapFileService.Challenge != null;
    }
    private async Task<ExecuteActionResult> ExecuteToolAsync()
    {
        var challenge = MapFileService.Challenge;
        if (challenge is null)
            return new ExecuteActionResult(ExecuteActionResultStatus.Failure, "No map loaded.");

        var embeddedItemExtractor = new TM_GenericMapping.Maps.EmbeddedItemExtractor();

        var zipStramResult = embeddedItemExtractor.GetEmbeddedZipStream(challenge);
        if (zipStramResult.IsFailure)
        {
            ToolMessageService.AddError($"Failed to extract embedded items.", zipStramResult, "Embedded Item Extractor");
            return new ExecuteActionResult(ExecuteActionResultStatus.Failure, "Failed to extract embedded items.");
        }
        using var zipStream = zipStramResult.Value;
        zipStream.Position = 0;
        using var zipBytesStream = new MemoryStream();
        await zipStream.CopyToAsync(zipBytesStream);
        var zipBytes = zipBytesStream.ToArray();
        var zipFileName = $"{challenge.MapName}_EmbeddedItems.zip";

        _exportItems = new[]
        {
            new ExportableItem { FileName = zipFileName, GetBytes = () => zipBytes }
        };
        StateHasChanged();

        return new ExecuteActionResult(ExecuteActionResultStatus.Success, "Successfully extracted embedded items.");
    }

}
