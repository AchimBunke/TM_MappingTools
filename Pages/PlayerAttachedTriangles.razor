@page "/player-attached-triangles"
@inject TM_MappingTools.Services.OperationHistoryService OperationHistoryService


<PageTitle>Player Attached Triangles</PageTitle>

<div class="tool-page">
    <ToolPageHeader IconClass="bi bi-paperclip"
                    Title="Player-Attached 3D Triangles"
                    Description="Attach 3D triangles to the player. These tracks will move relative to the car.">
        <HeaderActions>
            <button type="button"
                    class="btn btn-outline-secondary btn-sm tool-help-toggle"
                    @onclick="ToggleHelpPanel"
                    aria-expanded="@showHelpPanel"
                    aria-controls="playerTrianglesHelpPanel">
                <span class="bi @(showHelpPanel ? "bi-x-circle" : "bi-info-circle")" aria-hidden="true"></span>
                @(showHelpPanel ? "Hide details" : "How this works")
            </button>
        </HeaderActions>
    </ToolPageHeader>
    <div class="tool-page-body">
        <div class="tool-page-layout @(showHelpPanel ? "tool-page-layout-with-help" : string.Empty)">
            <div class="tool-page-sidebar">
                <div class="tool-panel tool-action-panel">
                    <div class="tool-panel-header">
                        <h2 class="tool-panel-title">Track Selection</h2>
                    </div>
                    <TrackSelector @bind-SelectedTracks="selectedTracks" />
                </div>
            </div>
            <div class="tool-page-main">
                <div class="tool-panel tool-action-panel">
                    <div class="tool-panel-header">
                        <h2 class="tool-panel-title">Actions</h2>
                    </div>
                    <ExecuteAction SelectedTracks="selectedTracks"
                                Execute="ExecuteToolAsync"
                                UseSelectedTracks="true" 
                                Tooltip="Execute the tool with the selected tracks."/>
                </div>

                <div class="tool-panel">
                    <div class="tool-panel-header">
                        <h2 class="tool-panel-title">Parameters</h2>
                    </div>
                    <ParameterInput Definitions="parameterDefinitions"
                                    Values="parameterValues"
                                    ValuesChanged="OnParameterValuesChanged" />
                </div>

            </div>

            @if (showHelpPanel)
            {
                <ToolHelpSidebar PanelId="playerTrianglesHelpPanel"
                                 Title="Detailed Info"
                                 Description="How player-attached triangles work and when to use visibility ensurance.">
                    <h3>What happens when you click Execute</h3>
                    <p>For each selected track, this tool converts triangle geometry so it moves relative to the player vehicle rather than staying fixed in world space.</p>

                    <h3>Ensure Visibility</h3>
                    <p>When enabled, extra vertices are added to reduce culling artifacts so triangles remain visible from all camera angles and distances.</p>

                    <h3>Ensurance Vertex Distance</h3>
                    <p>This sets how far those helper vertices are placed. Larger values may improve culling robustness.</p>

                    <h3>Practical workflow</h3>
                    <p>If you want your relative triangles to remain visible from all camera angles, enable Ensure Visibility. The only time you should disable it is if you purposely want to only show these triangles when driving in a certain direction. Though even then the culling behavior is insanely hard to predict and depends on screen resolution and camera settings.</p>
                </ToolHelpSidebar>
            }
        </div>
    </div>
</div>

@code {
    private List<TrackData> selectedTracks = new();
    private bool showHelpPanel;

    private readonly List<ToolParameterDefinition> parameterDefinitions = new()
    {
        new()
        {
            Key = "ensureVisibility",
            Label = "Ensure Visibility",
            Tooltip = "If disabled, 3DTriangles may not render depending on your camera direction and distance. Enabling this will ensure they are always visible by added extra vertices to the track preventing erroneous culling.",
            Kind = ToolParameterKind.Bool,
            DefaultValue = true,
        },
        new()
        {
            Key = "ensuranceVertexDistance",
            Label = "Ensurance Vertex Distance",
            Tooltip = "If Ensure Visibility is enabled, this controls the distance of the extra vertices added to ensure visibility. Low values may cause erroneous culling to appear.",
            Kind = ToolParameterKind.Float,
            DefaultValue = 10000f,
            Min = 0.1,
            Max = 100000,
            Step = 100,
        },
    };

    private ToolParameterValues parameterValues = new();

    private Task OnParameterValuesChanged(ToolParameterValues values)
    {
        parameterValues = values;
        return Task.CompletedTask;
    }

    private void ToggleHelpPanel()
    {
        showHelpPanel = !showHelpPanel;
    }

    private async Task<string?> ExecuteToolAsync()
    {
        foreach (var trackData in selectedTracks)
        {
            TracksUtils.MakeTrianglesRelative(trackData.MediaTrack.Track, 
                parameterValues.GetBool("ensureVisibility"), 
                parameterValues.GetFloat("ensuranceVertexDistance"));
        }
        OperationHistoryService.AddOperation("Player Attached Triangles");

        return null;
    }
}
